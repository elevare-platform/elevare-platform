# ============================================================
# Elevare Backend — Environment Variables
# Copy this file to .env and fill in all values before running.
# NEVER commit .env to version control.
# ============================================================

# ─── Application ─────────────────────────────────────────────
APP_NAME=Elevare API
APP_VERSION=1.0.0
ENVIRONMENT=production          # development | production
DEBUG=false                     # MUST be false in production — exposes stack traces if true

# ─── URLs ────────────────────────────────────────────────────
# APP_URL is used in email links — must be the live frontend domain
APP_URL=https://your-frontend.vercel.app

# ─── Database ────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/elevare_db
REDIS_URL=redis://:PASSWORD@HOST:6379/0   # include password in production

# ─── Security ────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
HMAC_SECRET=

# ─── JWT ─────────────────────────────────────────────────────
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── Cookies ─────────────────────────────────────────────────
COOKIE_SECURE=true              # MUST be true in production (requires HTTPS)

# ─── CORS ────────────────────────────────────────────────────
# Exact production origins only — no localhost in production
CORS_ORIGINS=["https://your-frontend.vercel.app"]

# ─── Email ───────────────────────────────────────────────────
EMAIL_STUB_MODE=false           # MUST be false in production — true only in dev/CI
RESEND_API_KEY=
MAIL_FROM=noreply@yourdomain.com

# ─── Cloudflare R2 Storage ───────────────────────────────────
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_ENDPOINT_URL=
R2_REGION=auto
R2_PUBLIC_URL=

# ─── AI Services ─────────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
OPENAI_API_KEY=                 # Required for Phase 12 semantic matching

# ─── Invite & Verification ───────────────────────────────────
INVITE_EXPIRY=3                 # days
EMAIL_VERIFICATION_TOKEN_EXPIRY=24  # hours

# ─── Feature Flags ───────────────────────────────────────────
SHOW_AI_SCORE_TO_CANDIDATES=false
DEFAULT_ACCESS_TOKEN_EXPIRY_DAYS=30

# ─── Contact / Site ──────────────────────────────────────────
CONTACT_EMAIL=info_admin@elevare.com.ng
SALES_EMAIL=hr@elevare.com.ng
SITE_URL=https://elevare.com.ng/
